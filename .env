# =============================================================
# Variáveis de ambiente do AI-Powered Threat Hunter
# ATENÇÃO: nunca versione este arquivo com credenciais reais
# =============================================================

# Versão do ELK Stack (mantenha os três na mesma versão)
ELK_VERSION=8.13.0

# Elasticsearch
ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme123

# Kibana
KIBANA_PORT=5601

# Logstash
LOGSTASH_PORT_TCP=5044
LOGSTASH_PORT_UDP=5045
LOGSTASH_PORT_HTTP=8080

# Coletor de logs
COLLECTOR_HOST=logstash
COLLECTOR_PORT=5044
LOG_LEVEL=INFO
